generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id            String   @id @default(uuid())
  modelName     String
  dailyPrice    Float
  quantity      Int      @default(1)
  imageUrl      String
  galleryImages String   @db.Text
  specs         String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}